# --- docker-compose (services db + ollama) ---
POSTGRES_USER=mira
POSTGRES_PASSWORD=mira
POSTGRES_DB=mira
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GEN_MODEL=qwen2.5:1.5b-instruct

# --- API (cmd/api) ---
ADDR=:8080
SEED=true
ENRICHMENT_WORKERS=4
ENRICHMENT_QUEUE_SIZE=256
# Génération LLM sur CPU : plus lente qu'un simple embedding.
ENRICHMENT_TIMEOUT=30s

# DATABASE_URL et OLLAMA_URL sont fixés automatiquement par docker-compose.yml
# pour le service "api" (hôtes internes "db" et "ollama"). Pour lancer l'API
# directement sur l'hôte (go run ./cmd/api) contre les services Docker
# (db + ollama exposés sur localhost), décommenter :
# DATABASE_URL=postgres://mira:mira@localhost:5432/mira?sslmode=disable
# OLLAMA_URL=http://localhost:11434

# --- CLI ---
# MIRA_API_URL=http://localhost:8080
